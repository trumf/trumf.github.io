<!DOCTYPE html>
<html lang="{{ metadata.language }}">

<head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="{{ description or metadata.description }}" />
    <title>{{ title or metadata.title }} | Simon Rosenqvist</title>

    <!-- Styles and Resources -->
    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/image-fullscreen.css" />
    <link rel="icon" type="image/svg+xml" href="/public/images/favicon-light.svg" media="(prefers-color-scheme: light)">
    <link rel="icon" type="image/svg+xml" href="/public/images/favicon-dark.svg" media="(prefers-color-scheme: dark)">
    <link rel="icon" type="image/svg+xml" href="/public/images/favicon.svg">

    <!-- Open Graph Meta Tags -->
    <meta property="og:title" content="{{ title or metadata.title }} | Simon Rosenqvist">
    <meta property="og:description" content="{{ description or metadata.description }}">
    <meta property="og:image" content="/public/images/favicon.svg">
    <meta property="og:url" content="{{ page.url | absoluteUrl }}">
    <meta property="og:type" content="website">

    <!-- Twitter Card Tags -->
    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="{{ title or metadata.title }} | Simon Rosenqvist">
    <meta name="twitter:description" content="{{ description or metadata.description }}">
    <meta name="twitter:image" content="/public/images/favicon.svg">

    <!-- RSS Feed -->
    <link rel="alternate" href="{{ metadata.feed.url or '/feed.xml' | url }}" type="application/rss+xml"
        title="{{ metadata.title }}">
</head>

<body>
    <header>
        <nav class="navbar-container">
            {% include "components/navbar.html" %}
        </nav>
        {% if hero %}
        <div class="hero-text">
            <h1 class="display-1">{{ hero }}</h1>
        </div>
        {% endif %}
    </header>

    <main>
        {{ content | safe }}
    </main>

    <footer role="contentinfo" class="footer_padding bg_black">
        <div style="width: 100%; display: flex; justify-content: center;">
            {% include "components/footer.html" %}
        </div>
    </footer>

    <script src="{{ '/js/image-fullscreen.js' | url }}" defer></script>
</body>

</html>