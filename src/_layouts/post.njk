---
layout: base.njk
---

<article class="section_padding">
    <div class="section_content">

        <header class="post-header">
            <h1 class="display-1">{{ title }}</h1>
            <div class="post-meta">
                <time datetime="{{ date | dateToISO }}">{{ date | dateToISO }}</time>
                {% if tags %}
                <div class="tags">
                    {% for tag in tags %}
                    <span class="tag">{{ tag }}</span>
                    {% endfor %}
                </div>
                {% endif %}
            </div>
        </header>

        <div class="post-content">
            {{ content | safe }}
        </div>
        <a href="/" class="button" style="margin-top: var(--spacing-lg);">Back Home</a>
    </div>

</article>
